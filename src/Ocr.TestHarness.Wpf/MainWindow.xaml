                                                       Text="{Binding SelectedTableDisplayStatus}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       Margin="0,0,0,8"/>
                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding SelectedTableDisplayView}"
                                                      AutoGenerateColumns="True"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      RowHeaderWidth="0"
                                                      MinHeight="140"
                                                      MaxHeight="260"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                                <DataGrid.Resources>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCellTextStyle}"/>
                                                </DataGrid.Resources>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="3" Text="Header Columns" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <DataGrid Grid.Row="4"
                                              ItemsSource="{Binding SelectedTableHeaderColumns}"
