<Window x:Class="Ocr.TestHarness.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:Ocr.TestHarness.Wpf.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OCR Test Harness"
        Height="1040"
        Width="1620"
        MinHeight="820"
        MinWidth="1280"
        Background="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F8FA"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9DFE8"/>
        <SolidColorBrush x:Key="BorderBrushMuted" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#334155"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#1F2937"/>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,0,18,18"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="14,10"
                                Margin="0,0,8,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#D5DDE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CBD5E1" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WrappedCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="OverlayTooltipBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <DataTemplate DataType="{x:Type viewModels:PreviewOverlayItem}" x:Key="PreviewOverlayItemTemplate">
            <Grid Width="{Binding Width}"
                  Height="{Binding Height}"
                  Background="Transparent"
                  IsHitTestVisible="{Binding HasTooltip}"
                  ToolTipService.ShowDuration="30000"
                  ToolTipService.InitialShowDelay="100"
                  ToolTipService.HorizontalOffset="10"
                  ToolTipService.VerticalOffset="10">
                <Rectangle x:Name="OverlayRect"
                           Width="{Binding Width}"
                           Height="{Binding Height}"
                           RadiusX="2"
                           RadiusY="2"
                           Stroke="#4F6B8A"
                           StrokeThickness="1.2"
                           Fill="#104F6B8A"/>
                <Grid.ToolTip>
                    <ToolTip Placement="MousePoint">
                        <Border Style="{StaticResource OverlayTooltipBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding RecognizedText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConfidenceText, StringFormat=Confidence: {0}}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding PageText}"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </ToolTip>
                </Grid.ToolTip>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Line">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#0F766E" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#120F766E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Block">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#7C3AED" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#127C3AED" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Table">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#9A6700" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#149A6700" />
                    <Setter TargetName="OverlayRect" Property="StrokeThickness" Value="1.4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Region">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#C2410C" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#12C2410C" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="OverlayRect" Property="StrokeThickness" Value="1.8" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#1B4F6B8A" />
                </Trigger>
                <DataTrigger Binding="{Binding HasTooltip}" Value="False">
                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="OCR Test Harness" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Professional validation workspace for exercising Ocr.Core options, preview artifacts, structured output, tables, fields, and diagnostics."
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="Harness Coverage" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding OptionsCoverageSummary}" Margin="0,8,0,4" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding FeatureCoverageSummary}" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Run Workspace" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Content="Browse File"
                        Width="110"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseFileCommand}"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Content="{Binding RunButtonText}"
                        Width="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RunOcrCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Run Status" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding OutputJsonPath, StringFormat=Output JSON: {0}}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
        <TabControl SelectedIndex="1">
            <TabItem Header="Options">
                <ScrollViewer Margin="14"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Core OCR" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Target DPI" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetDpi, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Language" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Page Seg Mode" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PageSegMode, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Engine Mode" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EngineMode, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Profile Name" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Preserve Spaces" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding PreserveInterwordSpaces}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Preprocessing" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Enable Deskew" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableDeskew}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Deskew Degrees" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MaxDeskewDegrees, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Deskew Angle Step" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DeskewAngleStep, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Min Deskew Confidence" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MinDeskewConfidence, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Enable Denoise" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding EnableDenoise}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Denoise Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding DenoiseMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Denoise Kernel" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding DenoiseKernel, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Noise Filtering" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding EnableNoiseFiltering}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="4" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Artifacts And Output" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Enable Binarization" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableBinarization}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Binarization Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BinarizationMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Contrast Enhancement" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding EnableContrastEnhancement}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Contrast Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ContrastMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Save JSON To Disk" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding SaveJsonToDisk}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Save Debug Artifacts" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding SaveDebugArtifacts}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Save Token Overlay" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding SaveTokenOverlay}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Output Folder" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                <Grid Grid.Row="8" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="Browse" Width="86" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputFolderCommand}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Summary">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Document Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="File Name" Foreground="#475569"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryFileName}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="File Type" Foreground="#475569"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryFileType}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Page Count" Foreground="#475569"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryPageCount}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Timing Summary (ms)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total" Foreground="#475569"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryTotalMs}"/>
