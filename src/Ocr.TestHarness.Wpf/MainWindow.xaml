<Window x:Class="Ocr.TestHarness.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OCR Test Harness"
        Height="1040"
        Width="1620"
        MinHeight="820"
        MinWidth="1280"
        Background="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9DFE8"/>
        <SolidColorBrush x:Key="BorderBrushMuted" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#334155"/>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,0,18,18"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#D5DDE7"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="OCR Test Harness" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Professional validation workspace for exercising Ocr.Core options, preview artifacts, structured output, tables, fields, and diagnostics."
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="Harness Coverage" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{Binding OptionsCoverageSummary}" Margin="0,8,0,4" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding FeatureCoverageSummary}" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Run Workspace" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Content="Browse File"
                        Width="110"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseFileCommand}"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Content="{Binding RunButtonText}"
                        Width="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RunOcrCommand}"/>
            </Grid>
        </Border>

        <Expander Grid.Row="2"
                  Header="OCR Options"
                  IsExpanded="True"
                  Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrushSoft}"
                  BorderThickness="1"
                  Padding="16"
                  Margin="0,0,0,14">
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Core OCR" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Target DPI" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetDpi, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Language" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Page Seg Mode" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PageSegMode, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Engine Mode" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EngineMode, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Profile Name" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Preserve Spaces" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding PreserveInterwordSpaces}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Preprocessing" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enable Deskew" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableDeskew}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Deskew Degrees" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MaxDeskewDegrees, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Deskew Angle Step" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DeskewAngleStep, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Min Deskew Confidence" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MinDeskewConfidence, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Enable Denoise" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding EnableDenoise}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Denoise Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding DenoiseMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Denoise Kernel" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding DenoiseKernel, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Noise Filtering" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding EnableNoiseFiltering}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Artifacts And Output" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enable Binarization" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableBinarization}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Binarization Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BinarizationMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Contrast Enhancement" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding EnableContrastEnhancement}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Contrast Method" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ContrastMethod, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Save JSON To Disk" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding SaveJsonToDisk}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Save Debug Artifacts" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding SaveDebugArtifacts}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Save Token Overlay" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding SaveTokenOverlay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Output Folder" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                        <Grid Grid.Row="8" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse" Width="86" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputFolderCommand}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Expander>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Run Status" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding OutputJsonPath, StringFormat=Output JSON: {0}}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
        <TabControl>
            <TabItem Header="Summary">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Document Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="File Name" Foreground="#475569"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryFileName}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="File Type" Foreground="#475569"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryFileType}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Page Count" Foreground="#475569"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryPageCount}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Timing Summary (ms)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total" Foreground="#475569"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryTotalMs}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Document OCR" Foreground="#475569"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryDocumentOcrMs}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Render" Foreground="#475569"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryRenderMs}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Preprocess" Foreground="#475569"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SummaryPreprocessMs}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="OCR" Foreground="#475569"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SummaryOcrMs}"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Layout" Foreground="#475569"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SummaryLayoutMs}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Quality Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Token Count" Foreground="#475569"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryTokenCount}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mean Confidence" Foreground="#475569"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryMeanConfidence, StringFormat={}{0:F3}}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Low-Confidence Tokens" Foreground="#475569"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryLowConfidenceTokenCount}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Warnings" Foreground="#475569"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SummaryWarningCount}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Errors" Foreground="#475569"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SummaryErrorCount}"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Detected Tables" Foreground="#475569"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SummaryTableCount}"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Mean Table Confidence" Foreground="#475569"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SummaryMeanTableConfidence, StringFormat={}{0:F3}}"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Table Methods" Foreground="#475569"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SummaryTableMethods}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="9" Grid.Column="0" Text="KV Candidates" Foreground="#475569"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SummaryKeyValueCandidateCount}"/>
                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Promoted Fields" Foreground="#475569"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SummaryPromotedFieldCount}"/>
                                <TextBlock Grid.Row="11" Grid.Column="0" Text="Top Table" Foreground="#475569"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding SummaryHighestConfidenceTable}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="12" Grid.Column="0" Text="Checkboxes" Foreground="#475569"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SummaryCheckboxCount}"/>
                                <TextBlock Grid.Row="13" Grid.Column="0" Text="Radios" Foreground="#475569"/>
                                <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SummaryRadioCount}"/>
                                <TextBlock Grid.Row="14" Grid.Column="0" Text="Checked Regions" Foreground="#475569"/>
                                <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SummaryCheckedRegionCount}"/>
                                <TextBlock Grid.Row="15" Grid.Column="0" Text="Unique Words (Doc)" Foreground="#475569"/>
                                <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding SummaryUniqueWordCount}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Output JSON Path" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SummaryOutputJsonPath}" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="160"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Per-Page Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PageSummaries}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Page #" Binding="{Binding PageIndex}" Width="70"/>
                                    <DataGridTextColumn Header="Token Count" Binding="{Binding TokenCount}" Width="110"/>
                                    <DataGridTextColumn Header="Mean Confidence" Binding="{Binding MeanConfidence, StringFormat={}{0:F3}}" Width="130"/>
                                    <DataGridTextColumn Header="Render ms" Binding="{Binding RenderMs}" Width="100"/>
                                    <DataGridTextColumn Header="Preprocess ms" Binding="{Binding PreprocessMs}" Width="120"/>
                                    <DataGridTextColumn Header="OCR ms" Binding="{Binding OcrMs}" Width="100"/>
                                    <DataGridTextColumn Header="Layout ms" Binding="{Binding LayoutMs}" Width="100"/>
                                    <DataGridTextColumn Header="Table Count" Binding="{Binding TableCount}" Width="100"/>
                                    <DataGridTextColumn Header="Table Confidence" Binding="{Binding MeanTableConfidence, StringFormat={}{0:F3}}" Width="130"/>
                                    <DataGridTextColumn Header="Checkboxes" Binding="{Binding CheckboxCount}" Width="100"/>
                                    <DataGridTextColumn Header="Radios" Binding="{Binding RadioCount}" Width="90"/>
                                    <DataGridTextColumn Header="Checked" Binding="{Binding CheckedRegionCount}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Text="Promoted Fields" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
                            <DataGrid Grid.Row="3"
                                      ItemsSource="{Binding FieldSummaries}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Field Id" Binding="{Binding FieldId}" Width="220"/>
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="220"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat={}{0:F3}}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="JSON">
                <Grid Margin="14">
                    <Border BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="8">
                        <TextBox Text="{Binding JsonOutput}"
                                 IsReadOnly="True"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Log">
                <Grid Margin="14">
                    <Border BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="8">
                        <ListBox ItemsSource="{Binding LogLines}" FontSize="13"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Preview">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Page" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PreviewPages}"
                                  SelectedItem="{Binding SelectedPreviewPage}"
                                  VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="View" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding PreviewViewOptions}"
                                  SelectedItem="{Binding SelectedPreviewView}"
                                  VerticalContentAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Zoom In" Width="90" Margin="0,0,8,0" Command="{Binding ZoomInCommand}"/>
                        <Button Content="Zoom Out" Width="90" Margin="0,0,8,0" Command="{Binding ZoomOutCommand}"/>
                        <Button Content="Fit to Window" Width="112" Command="{Binding FitToWindowCommand}"/>
                    </StackPanel>

                    <Border Grid.Row="2" BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Background="#FAFBFD">
                        <Grid>
                            <TextBlock Text="{Binding PreviewStatusMessage}"
                                       Foreground="#475569"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="18"/>
                            <ScrollViewer SizeChanged="PreviewScrollViewer_OnSizeChanged"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Image Source="{Binding PreviewImage}"
                                       Stretch="None"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}"/>
                                    </Image.LayoutTransform>
                                </Image>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Words">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Scope" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding WordScopeOptions}"
                                      SelectedItem="{Binding SelectedWordScope}"
                                      VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Word Count" VerticalAlignment="Center" Foreground="#475569"/>
                            <TextBlock Grid.Column="4" Text="{Binding DisplayWordCount}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="8">
                        <ListBox ItemsSource="{Binding DisplayWords}" FontSize="13"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Tables">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Detected Tables" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding TableSummaries}"
                                      SelectedItem="{Binding SelectedTableSummary}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Page" Binding="{Binding PageIndex}" Width="60"/>
                                    <DataGridTextColumn Header="Table Id" Binding="{Binding TableId}" Width="110"/>
                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="95"/>
                                    <DataGridTextColumn Header="Conf." Binding="{Binding Confidence, StringFormat={}{0:F3}}" Width="70"/>
                                    <DataGridTextColumn Header="Rows" Binding="{Binding RowCount}" Width="60"/>
                                    <DataGridTextColumn Header="Cols" Binding="{Binding ColumnCount}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="#D9DFE8" BorderThickness="1" CornerRadius="6" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Selected Table"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          PanningMode="VerticalOnly">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="170"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="170"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Table Id" Foreground="#475569"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTableId}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Page Index" Foreground="#475569"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedTablePageIndex}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Method" Foreground="#475569"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTableMethod}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Explicit Gridlines" Foreground="#475569"/>
                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedTableHasExplicitGridLines}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Confidence" Foreground="#475569"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTableConfidence, StringFormat={}{0:F3}}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Coverage Ratio" Foreground="#475569"/>
                                        <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SelectedTableTokenCoverageRatio, StringFormat={}{0:F3}}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="BBox" Foreground="#475569"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedTableBboxText}" TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Table Overlay" Foreground="#475569"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedTableOverlayPath}" TextTrimming="CharacterEllipsis"/>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="{Binding TablesStatusMessage}" Foreground="#64748B" Margin="0,0,0,6"/>

                                    <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="#FAFBFD">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Visual Table Preview" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding SelectedTableDisplayStatus}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       Margin="0,0,0,8"/>
                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding SelectedTableDisplayView}"
                                                      AutoGenerateColumns="True"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      RowHeaderWidth="0"
                                                      MinHeight="140"
                                                      MaxHeight="260"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="3" Text="Header Columns" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <DataGrid Grid.Row="4"
                                              ItemsSource="{Binding SelectedTableHeaderColumns}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Col" Binding="{Binding ColIndex}" Width="60"/>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="220"/>
                                            <DataGridTextColumn Header="Conf." Binding="{Binding Confidence, StringFormat={}{0:F3}}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Grid.Row="5" Text="Raw Header Cells" FontWeight="SemiBold" Margin="0,10,0,6"/>
                                    <DataGrid Grid.Row="6"
                                              ItemsSource="{Binding SelectedTableHeaderCells}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Row" Binding="{Binding RowIndex}" Width="60"/>
                                            <DataGridTextColumn Header="Col" Binding="{Binding ColIndex}" Width="60"/>
                                            <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
                                            <DataGridTextColumn Header="Conf." Binding="{Binding Confidence, StringFormat={}{0:F3}}" Width="90"/>
                                            <DataGridTextColumn Header="Tokens" Binding="{Binding TokenCount}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Grid.Row="7" Text="Raw Cells" FontWeight="SemiBold" Margin="0,10,0,6"/>
                                    <DataGrid Grid.Row="8"
                                              ItemsSource="{Binding SelectedTableRawCells}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Row" Binding="{Binding RowIndex}" Width="60"/>
                                            <DataGridTextColumn Header="Col" Binding="{Binding ColIndex}" Width="60"/>
                                            <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
                                            <DataGridTextColumn Header="Conf." Binding="{Binding Confidence, StringFormat={}{0:F3}}" Width="90"/>
                                            <DataGridTextColumn Header="Tokens" Binding="{Binding TokenCount}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        </Border>
    </Grid>
</Window>
