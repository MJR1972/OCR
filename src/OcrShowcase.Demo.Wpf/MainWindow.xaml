<Window x:Class="OcrShowcase.Demo.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:OcrShowcase.Demo.Wpf.Models"
        xmlns:resources="clr-namespace:OcrShowcase.Demo.Wpf.Resources"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}"
        Width="1600"
        Height="980"
        MinWidth="1320"
        MinHeight="840"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <resources:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F8FA" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DCE2" />
        <SolidColorBrush x:Key="DividerBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#334155" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="NeutralButtonBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="NeutralButtonPressedBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="PreviewPatternBrush" Color="#E2E8F0" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryToolbarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource NeutralButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource NeutralButtonPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource NeutralButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="14,10"
                                Margin="0,0,8,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource DividerBrush}" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,9" />
        </Style>

        <Style x:Key="PreviewToggleStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="OverlayBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="3" />
        </Style>

        <Style x:Key="OverlayTooltipBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="EmptyStateBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SummaryDetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <DataTemplate x:Key="SummaryDetailCompactTemplate">
            <Border Margin="0,0,0,8"
                    Padding="0,0,0,8"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Label}"
                               Style="{StaticResource SummaryDetailLabelStyle}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,3,0,0"
                               Text="{Binding Value}"
                               Style="{StaticResource SummaryValueStyle}"
                               FontSize="12"
                               FontWeight="Normal"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:PreviewOverlayItem}" x:Key="OverlayItemTemplate">
            <Grid Width="{Binding Width}"
                  Height="{Binding Height}"
                  Background="Transparent"
                  IsHitTestVisible="{Binding HasTooltip}"
                  ToolTipService.ShowDuration="30000"
                  ToolTipService.InitialShowDelay="100"
                  ToolTipService.HorizontalOffset="10"
                  ToolTipService.VerticalOffset="10">
                <Rectangle x:Name="OverlayRect"
                           Width="{Binding Width}"
                           Height="{Binding Height}"
                           RadiusX="2"
                           RadiusY="2"
                           StrokeThickness="1.2"
                           Fill="#10000000" />
                <Border x:Name="OverlayBadge"
                        Style="{StaticResource OverlayBadgeStyle}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="OverlayBadgeText"
                               Text="{Binding Label}"
                               FontSize="9"
                               FontWeight="SemiBold" />
                </Border>
                <Grid.ToolTip>
                    <ToolTip Placement="MousePoint"
                             Visibility="{Binding HasTooltip, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Style="{StaticResource OverlayTooltipBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding RecognizedText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConfidenceText, StringFormat=Confidence: {0}}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding PageText}"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </ToolTip>
                </Grid.ToolTip>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Word">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#4F6B8A" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#104F6B8A" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="OverlayRect" Property="StrokeThickness" Value="1.8" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#1B4F6B8A" />
                </Trigger>
                <DataTrigger Binding="{Binding Kind}" Value="Field">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#0F766E" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#120F766E" />
                    <Setter TargetName="OverlayBadge" Property="Background" Value="#DFF7F4" />
                    <Setter TargetName="OverlayBadge" Property="BorderBrush" Value="#0F766E" />
                    <Setter TargetName="OverlayBadge" Property="BorderThickness" Value="1" />
                    <Setter TargetName="OverlayBadge" Property="Visibility" Value="Visible" />
                    <Setter TargetName="OverlayBadgeText" Property="Foreground" Value="#0F766E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Table">
                    <Setter TargetName="OverlayRect" Property="Stroke" Value="#9A6700" />
                    <Setter TargetName="OverlayRect" Property="Fill" Value="#149A6700" />
                    <Setter TargetName="OverlayRect" Property="StrokeThickness" Value="1.4" />
                    <Setter TargetName="OverlayBadge" Property="Background" Value="#FFF5D6" />
                    <Setter TargetName="OverlayBadge" Property="BorderBrush" Value="#9A6700" />
                    <Setter TargetName="OverlayBadge" Property="BorderThickness" Value="1" />
                    <Setter TargetName="OverlayBadge" Property="Visibility" Value="Visible" />
                    <Setter TargetName="OverlayBadgeText" Property="Foreground" Value="#9A6700" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Label}" Value="{x:Null}">
                    <Setter TargetName="OverlayBadge" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Label}" Value="">
                    <Setter TargetName="OverlayBadge" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasTooltip}" Value="False">
                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="24,18"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding ApplicationTitle}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Professional OCR product walkthrough for portfolio captures, stakeholder demos, and integration previews."
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Load Document"
                            Command="{Binding LoadDocumentCommand}"
                            Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    <Button Content="Run OCR"
                            Command="{Binding RunOcrCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Export JSON"
                            Command="{Binding ExportJsonCommand}"
                            Style="{StaticResource SecondaryToolbarButtonStyle}"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="20,18,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Document Preview"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Rendered page preview with production-style overlays sized for demos and screenshot capture."
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <Grid Grid.Column="1"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Page"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button Content="&#x2039;"
                                        Command="{Binding PreviousPreviewPageCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        MinWidth="34"
                                        Padding="7,6"
                                        Margin="0,0,6,0" />
                                <ComboBox Width="88"
                                          ItemsSource="{Binding PreviewPageNumbers}"
                                          SelectedValuePath="."
                                          SelectedValue="{Binding SelectedPreviewPageNumber}"
                                          Margin="0,0,8,0"
                                          Padding="6,4"
                                          IsReadOnly="True"
                                          IsEditable="False"
                                          VerticalContentAlignment="Center" />
                                <TextBlock Text="{Binding PreviewPageIndicator}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button Content="&#x203A;"
                                        Command="{Binding NextPreviewPageCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        MinWidth="34"
                                        Padding="7,6"
                                        Margin="0" />
                            </StackPanel>

                            <WrapPanel Grid.Row="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       ItemHeight="32">
                                <CheckBox Content="Show Words"
                                          IsChecked="{Binding ShowWordOverlays}"
                                          Style="{StaticResource PreviewToggleStyle}" />
                                <CheckBox Content="Show Fields"
                                          IsChecked="{Binding ShowFieldOverlays}"
                                          Style="{StaticResource PreviewToggleStyle}" />
                                <CheckBox Content="Show Tables"
                                          IsChecked="{Binding ShowTableOverlays}"
                                          Style="{StaticResource PreviewToggleStyle}" />
                                <Button Content="-"
                                        Command="{Binding ZoomOutCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        MinWidth="36"
                                        Padding="8,6"
                                        Margin="6,0,8,0" />
                                <TextBlock Text="{Binding PreviewZoomText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button Content="+"
                                        Command="{Binding ZoomInCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        MinWidth="36"
                                        Padding="8,6"
                                        Margin="0,0,8,0" />
                                <Button Content="Fit"
                                        Command="{Binding FitPreviewCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        MinWidth="50"
                                        Padding="10,6"
                                        Margin="0" />
                            </WrapPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="20,0,20,20"
                            CornerRadius="8"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid x:Name="PreviewViewport">
                            <Rectangle Margin="28"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Stroke="{StaticResource PreviewPatternBrush}"
                                       StrokeDashArray="3 5"
                                       Fill="#FCFDFE" />

                            <Border Visibility="{Binding HasPreviewImage, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Width="Auto"
                                    Height="Auto"
                                    MaxWidth="520"
                                    MaxHeight="680"
                                    Margin="40"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Grid Margin="32">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="{Binding PreviewHeaderTitle}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding PreviewSubheading}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>

                                    <Separator Grid.Row="1"
                                               Margin="0,20,0,26"
                                               Background="{StaticResource DividerBrush}" />

                                    <StackPanel Grid.Row="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                MaxWidth="320">
                                        <Border Width="80"
                                                Height="80"
                                                CornerRadius="40"
                                                Background="{StaticResource SurfaceMutedBrush}"
                                                BorderBrush="{StaticResource DividerBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="PDF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                        <TextBlock Text="No document preview yet"
                                                   Margin="0,20,0,8"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding PreviewPlaceholder}"
                                                   FontSize="13"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedFilePath}"
                                                   Margin="0,14,0,0"
                                                   FontSize="11"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Visibility="{Binding HasPreviewImage, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="28"
                                  SizeChanged="PreviewScrollHost_OnSizeChanged">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Canvas Width="{Binding PreviewSurfaceWidth}"
                                            Height="{Binding PreviewSurfaceHeight}"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True">
                                        <Image Canvas.Left="{Binding PreviewImageOffsetX}"
                                               Canvas.Top="{Binding PreviewImageOffsetY}"
                                               Source="{Binding PreviewImage}"
                                               Width="{Binding PreviewImageDisplayWidth}"
                                               Height="{Binding PreviewImageDisplayHeight}"
                                               Stretch="Fill" />

                                        <ItemsControl ItemsSource="{Binding VisibleOverlayItems}"
                                                      ItemTemplate="{StaticResource OverlayItemTemplate}"
                                                      SnapsToDevicePixels="True">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                        </ItemsControl>
                                    </Canvas>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="18"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid Margin="0,4,0,0">
                    <TabControl Background="Transparent"
                                BorderThickness="0"
                                Padding="20,0,20,20">
                        <TabItem Header="Summary">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="{Binding SummaryHeadline}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding SummaryNarrative}"
                                               Margin="0,8,0,20"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" />

                                    <Grid Visibility="{Binding HasSummaryData, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <ItemsControl ItemsSource="{Binding SummaryCards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardBorderStyle}"
                                                            Width="168"
                                                            Margin="0,0,14,14"
                                                            Padding="14">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding Value}"
                                                                       Margin="0,10,0,6"
                                                                       FontSize="22"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Detail}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Grid.Row="1"
                                                Style="{StaticResource CardBorderStyle}"
                                                Margin="0,2,0,0"
                                                Padding="14">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Processing Details"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                                <Grid Grid.Row="1"
                                                      Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <ItemsControl ItemsSource="{Binding LeftSummaryDetails}"
                                                                  ItemTemplate="{StaticResource SummaryDetailCompactTemplate}" />

                                                    <ItemsControl Grid.Column="2"
                                                                  ItemsSource="{Binding RightSummaryDetails}"
                                                                  ItemTemplate="{StaticResource SummaryDetailCompactTemplate}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Visibility="{Binding HasSummaryData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource EmptyStateBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Summary ready when OCR completes"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="Run OCR to populate document identity, timing metrics, token counts, confidence statistics, and detection totals."
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Fields">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Extracted Business Fields"
                                           Style="{StaticResource SectionTitleStyle}" />

                                <Grid Grid.Row="1"
                                      Margin="0,12,0,0">
                                    <DataGrid Visibility="{Binding HasFieldsData, Converter={StaticResource BoolToVisibilityConverter}}"
                                              ItemsSource="{Binding RecognizedFields}"
                                              IsReadOnly="True"
                                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Field"
                                                                Binding="{Binding FieldName}"
                                                                Width="1.2*" />
                                            <DataGridTextColumn Header="Value"
                                                                Binding="{Binding FieldValue}"
                                                                Width="2*" />
                                            <DataGridTextColumn Header="Confidence"
                                                                Binding="{Binding Confidence}"
                                                                Width="0.8*" />
                                            <DataGridTextColumn Header="Page"
                                                                Binding="{Binding Page}"
                                                                Width="0.5*" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border Visibility="{Binding HasFieldsData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource EmptyStateBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="No extracted fields"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="This document did not yield structured field promotions, or OCR has not been run yet."
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="JSON">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Structured OCR JSON"
                                           Style="{StaticResource SectionTitleStyle}" />

                                <Grid Grid.Row="1"
                                      Margin="0,12,0,0">
                                    <TextBox Visibility="{Binding HasJsonData, Converter={StaticResource BoolToVisibilityConverter}}"
                                             Text="{Binding JsonPreview}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             TextWrapping="NoWrap"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Background="{StaticResource PanelBrush}"
                                             BorderBrush="{StaticResource DividerBrush}"
                                             BorderThickness="1"
                                             Padding="14" />

                                    <Border Visibility="{Binding HasJsonData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource EmptyStateBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="JSON output unavailable"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="Run OCR to render the machine-readable contract in this monospaced viewer."
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Tables">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Detected Table Structures"
                                           Style="{StaticResource SectionTitleStyle}" />

                                <Grid Grid.Row="1"
                                      Margin="0,12,0,0">
                                    <ScrollViewer Visibility="{Binding HasTablesData, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DetectedTables}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardBorderStyle}"
                                                            Margin="0,0,0,12"
                                                            Padding="16">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding TableId}"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Confidence}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />

                                                            <StackPanel Grid.Row="1"
                                                                        Grid.ColumnSpan="2"
                                                                        Orientation="Horizontal"
                                                                        Margin="0,8,0,10">
                                                                <TextBlock Text="{Binding Page, StringFormat=Page {0}}"
                                                                           Margin="0,0,14,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding Method}"
                                                                           Margin="0,0,14,0"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding Shape, StringFormat={}{0} grid}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </StackPanel>

                                                            <Grid Grid.Row="2"
                                                                  Grid.ColumnSpan="2">
                                                                <DataGrid Visibility="{Binding HasDisplayableGrid, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                          ItemsSource="{Binding RowsView}"
                                                                          AutoGenerateColumns="True"
                                                                          IsReadOnly="True"
                                                                          CanUserAddRows="False"
                                                                          CanUserDeleteRows="False"
                                                                          CanUserResizeRows="False"
                                                                          HeadersVisibility="Column"
                                                                          GridLinesVisibility="Horizontal"
                                                                          RowHeaderWidth="0"
                                                                          SelectionMode="Single"
                                                                          SelectionUnit="FullRow"
                                                                          MinRowHeight="30"
                                                                          MaxHeight="320"
                                                                          ScrollViewer.CanContentScroll="True"
                                                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                          ScrollViewer.VerticalScrollBarVisibility="Auto" />

                                                                <Border Visibility="{Binding HasDisplayableGrid, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                                        Style="{StaticResource EmptyStateBorderStyle}"
                                                                        Padding="18">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Structured table grid unavailable"
                                                                                   FontSize="16"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                                        <TextBlock Text="{Binding EmptyStateMessage}"
                                                                                   Margin="0,8,0,0"
                                                                                   FontSize="12"
                                                                                   TextWrapping="Wrap"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Border Visibility="{Binding HasTablesData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource EmptyStateBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="No detected tables"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="Detected table regions and readable row previews will appear here when the OCR contract emits table structures."
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Log">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Processing Activity"
                                           Style="{StaticResource SectionTitleStyle}" />

                                <Grid Grid.Row="1"
                                      Margin="0,12,0,0">
                                    <ListView Visibility="{Binding HasLogData, Converter={StaticResource BoolToVisibilityConverter}}"
                                              ItemsSource="{Binding LogEntries}"
                                              BorderThickness="0"
                                              Background="Transparent">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource DividerBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="76" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Time}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="11" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Source}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="11" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Message}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Border Visibility="{Binding HasLogData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Style="{StaticResource EmptyStateBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="No log entries yet"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="Processing activity and OCR diagnostics will appear here after a run begins."
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="18,14"
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="Document"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding DocumentName}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="Pages"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding PageCount}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="Elapsed"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ElapsedTime}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Mean Confidence"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding MeanConfidence}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ProgressBar Width="110"
                                 Height="10"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                                 IsIndeterminate="True" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Width="360"
                               TextAlignment="Right"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
